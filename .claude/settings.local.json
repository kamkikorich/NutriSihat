{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx playwright:*)",
      "Bash(npm run:*)",
      "Bash(npx tsx:*)",
      "Bash(npm test:*)",
      "Bash(npx ecc-agentshield:*)",
      "mcp__browseros__*",
      "mcp__plugin_playwright_playwright__browser_*",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__*",
      "mcp__ecc__*",
      "Bash(ls -la \"D:/PanduanPemakananMama/.env\"*)",
      "Bash(npx vercel:*)",
      "WebSearch",
      "mcp__tavily__tavily_search",
      "Bash(npx supabase:*)",
      "Bash(npx web-push:*)",
      "mcp__playwright-mcp__browser_snapshot",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(npx -y web-push generate-vapid-keys)",
      "mcp__playwright-mcp__browser_navigate",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm list:*)",
      "Bash(node:*)",
      "Bash(curl -s https://api.github.com/repos/kamkikorich/NutriSihat/commits?per_page=3)",
      "Bash(ls -la supabase/migrations/*.sql)",
      "Bash(npx tsc:*)",
      "mcp__firecrawl__firecrawl_scrape",
      "mcp__plugin_vercel-plugin_vercel__list_teams",
      "mcp__plugin_vercel-plugin_vercel__list_projects",
      "mcp__plugin_vercel-plugin_vercel__list_deployments",
      "Bash(gh api:*)",
      "Bash(curl -s \"https://api.github.com/repos/kamkikorich/NutriSihat/commits?per_page=5\")",
      "mcp__plugin_vercel-plugin_vercel__deploy_to_vercel",
      "mcp__plugin_vercel-plugin_vercel__get_project",
      "mcp__plugin_vercel-plugin_vercel__get_deployment_build_logs",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "mcp__plugin_vercel-plugin_vercel__search_vercel_documentation",
      "mcp__plugin_vercel-plugin_vercel__get_deployment",
      "mcp__plugin_vercel-plugin_vercel__web_fetch_vercel_url",
      "Bash(curl -X POST https://nutrisihat.vercel.app/api/reminders/trigger -H \"Content-Type: application/json\" -H \"Authorization: Bearer test-cron-secret\" -v)",
      "Bash(dir \"D:\\\\PanduanPemakananMama\")",
      "Bash(npx next:*)",
      "Bash(findstr meal-planner:*)",
      "Bash(npx shadcn:*)",
      "Bash(vercel env:*)",
      "Bash(vercel:*)",
      "mcp__tavily__tavily_extract",
      "Bash(supabase --version)",
      "Bash(curl --version)",
      "Bash(git reset:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(eval *)",
      "Bash(* > /dev/*)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/secrets*)",
      "Write(**/credentials*)",
      "Read(**/.env)",
      "Read(**/.env.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Bash command executed\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] File write completed\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Session ended - files formatted\""
          }
        ]
      }
    ]
  }
}
