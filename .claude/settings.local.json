{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx playwright:*)",
      "Bash(npm run:*)",
      "Bash(npx tsx:*)",
      "Bash(npm test:*)",
      "Bash(npx ecc-agentshield:*)",
      "mcp__browseros__*",
      "mcp__plugin_playwright_playwright__browser_*",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__*",
      "mcp__ecc__*",
      "Bash(ls -la \"D:/PanduanPemakananMama/.env\"*)",
      "Bash(npx vercel:*)",
      "WebSearch",
      "mcp__tavily__tavily_search",
      "Bash(npx supabase:*)",
      "Bash(npx web-push:*)",
      "mcp__playwright-mcp__browser_snapshot",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(npx -y web-push generate-vapid-keys)",
      "mcp__playwright-mcp__browser_navigate",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm list:*)",
      "Bash(node:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(eval *)",
      "Bash(* > /dev/*)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/secrets*)",
      "Write(**/credentials*)",
      "Read(**/.env)",
      "Read(**/.env.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Bash command executed\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] File write completed\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Session ended - files formatted\""
          }
        ]
      }
    ]
  }
}
