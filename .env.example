# Supabase (REQUIRED - Get from https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase OAuth Redirect URLs (REQUIRED for Vercel deployment)
# Add this to your Supabase Dashboard > Authentication > URL Configuration:
# - Site URL: https://your-app.vercel.app
# - Redirect URLs: https://your-app.vercel.app/auth/callback
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Ollama AI (REQUIRED)
OLLAMA_API_URL=https://ollama.com/api
OLLAMA_API_KEY=your-api-key
OLLAMA_MODEL=gemini-3-flash-preview:cloud

# Local Ollama (for development only)
OLLAMA_LOCAL_URL=http://localhost:11434/api

# App Configuration
NEXT_PUBLIC_APP_NAME=NutriSihat
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Test Credentials (for E2E testing only - DO NOT use real credentials)
TEST_EMAIL=test@example.com
TEST_PASSWORD=testpassword123

# Vercel Environment (auto-set in production)
NODE_ENV=development

# IMPORTANT: Never commit .env.local to git!
# Copy this file to .env.local and fill in your actual values
